// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Universo de candidatos a grande/médio consumidor (Grupo A), construído a
// partir da base pública de CNPJ da Receita Federal filtrada por CNAE de
// setores intensivos em energia. Não confirma tecnicamente o subgrupo
// tarifário — é uma aproximação por perfil de atividade/porte.
model CandidateCompany {
  id                String   @id @default(cuid())
  cnpj              String   @unique
  cnpjRaiz          String
  razaoSocial       String
  nomeFantasia      String?
  cnae              String
  cnaeDescricao     String?
  uf                String
  municipio         String?
  porte             String?
  situacaoCadastral String?
  dataAbertura      String?
  capitalSocial     Float?
  source            String   @default("RFB")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([cnpjRaiz])
  @@index([uf])
  @@index([cnae])
}

// Consumidores já registrados como migrados para o mercado livre (ACL),
// obtidos do dataset público VAREJISTA_CONSUMIDOR da CCEE.
model MigratedConsumer {
  id              String   @id @default(cuid())
  cnpj            String
  cnpjRaiz        String
  nomeConsumidor  String
  agenteVarejista String?
  submercado      String?
  perfil          String?
  dataReferencia  String?
  source          String   @default("CCEE")
  rawData         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([cnpj, dataReferencia])
  @@index([cnpjRaiz])
}

// Histórico de execuções de sincronização das fontes externas
model SyncLog {
  id               String    @id @default(cuid())
  source           String
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           String    @default("running")
  recordsProcessed Int       @default(0)
  message          String?
}
